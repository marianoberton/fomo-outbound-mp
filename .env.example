# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- HubSpot ---
# Private app token con scopes: crm.objects.deals.read/write, crm.objects.contacts.read/write,
# crm.schemas.deals.read/write, crm.schemas.contacts.read/write, tickets, communication-preferences.
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PIPELINE_MAYORISTA_ID=
HUBSPOT_STAGE_SEGUIMIENTO_ID=
# Owner ID de la dueña (para tasks de freeze / propose-lost). Hardcoded por ahora.
HUBSPOT_DEAL_OWNER_ID=
# Inbox ID de la casilla de la vendedora (HubSpot Conversations / Single Send).
HUBSPOT_SALES_INBOX_ID=
# ID del template transaccional creado en HubSpot (merge tags: subject_override, body_override).
HUBSPOT_TRANSACTIONAL_EMAIL_ID=

# --- Meta WhatsApp Business ---
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_ACCESS_TOKEN=
# Token elegido por vos para el verify handshake del webhook (Meta lo manda en hub.verify_token).
META_WEBHOOK_VERIFY_TOKEN=
# App secret de la Meta App (NO el access token). Se usa para verificar la firma x-hub-signature-256.
META_APP_SECRET=

# --- HubSpot webhook signing ---
# Client secret de la Hubspot App con webhooks suscriptos. Verifica X-HubSpot-Signature-v3.
# Distinto del Private App Token: este viene de una public/dev app, no de un private app.
HUBSPOT_APP_SECRET=

# --- Approval queue (Fase 1) ---
# Token único para autenticar la UI de aprobación.
APPROVAL_QUEUE_TOKEN=
# 'on' (suspend antes de enviar) | 'off' (envía directo)
APPROVAL_MODE=on

# --- Storage ---
# LibSQL local para dev; Postgres URL para prod.
# LibSQL local para dev: file:./local.db
# LibSQL hosted (Turso): libsql://...
# Postgres para prod (recomendado, requiere concurrent updates para el cron evented):
#   postgres://user:pass@host:5432/db
DATABASE_URL=file:./local.db

# --- Server ---
PORT=4111

# --- Reporte semanal (workflow scheduled — opcional) ---
# Si está seteado, el workflow `metricas-semanal` postea el reporte a este webhook
# cada lunes 9 ART. Si no, solo loguea (queda en observability).
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Observability (Langfuse — opcional) ---
# Si están seteadas las dos keys, los traces de Mastra se exportan a Langfuse Cloud (o self-hosted).
# Si no, solo se persisten en el storage local (visibles desde Mastra Studio).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # default; cambiar para self-hosted
# LANGFUSE_ENVIRONMENT=production                # tag visible en la UI de Langfuse

# --- Stub mode ---
# Si está en 'true', las tools de HubSpot/Meta no llaman a APIs reales (loggean y devuelven mocks).
# Útil para correr local sin credenciales. Default: 'true' si las env vars de credenciales están vacías.
STUB_MODE=true
# Granular: si querés que HubSpot vaya real pero los envíos (WA + email) sean stub.
# Default: sigue a STUB_MODE. Útil para el smoke test (ver README).
# STUB_SEND=true

# --- Smoke test (npm run smoke) ---
# Contact que el smoke usa. Tiene que ser un email + teléfono que controles.
# SMOKE_CONTACT_EMAIL=
# SMOKE_CONTACT_PHONE=
# Si querés que el smoke envíe el mensaje de verdad (no solo stub), seteá esto.
# SMOKE_REAL_SEND=true
